@model List<UniHub.BL.Entities.Activity>
@{
    ViewData["Title"] = "Dashboard Administrateur Départemental";
    var userDept = (UniHub.BL.Entities.Department)ViewBag.UserDepartment;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-briefcase"></i> Dashboard Admin - Département @userDept</h1>
        <a asp-action="CreateActivity" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Créer une Activité
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Statistiques -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-calendar-event"></i> Total Activités</h5>
                    <h2 class="card-text">@Model.Count</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-check-circle"></i> Activités Publiées</h5>
                    <h2 class="card-text">@Model.Count(a => a.IsPublished)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-clock-history"></i> À venir</h5>
                    <h2 class="card-text">@Model.Count(a => a.StartDate > DateTime.Now)</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des activités -->
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4><i class="bi bi-list"></i> Mes Activités</h4>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="row">
                    @foreach (var activity in Model)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card h-100">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">@activity.Title</h5>
                                    @if (activity.IsPublished)
                                    {
                                        <span class="badge bg-success">Publié</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Brouillon</span>
                                    }
                                </div>
                                <div class="card-body">
                                    <p class="card-text">@activity.Description</p>
                                    <ul class="list-unstyled mb-3">
                                        <li><i class="bi bi-calendar"></i> <strong>Début:</strong> @activity.StartDate.ToString("dd/MM/yyyy HH:mm")</li>
                                        @if (activity.EndDate.HasValue)
                                        {
                                            <li><i class="bi bi-calendar"></i> <strong>Fin:</strong> @activity.EndDate.Value.ToString("dd/MM/yyyy HH:mm")</li>
                                        }
                                        @if (!string.IsNullOrEmpty(activity.Location))
                                        {
                                            <li><i class="bi bi-geo-alt"></i> <strong>Lieu:</strong> @activity.Location</li>
                                        }
                                        @if (activity.MaxParticipants.HasValue)
                                        {
                                            <li><i class="bi bi-people"></i> <strong>Participants max:</strong> @activity.MaxParticipants</li>
                                        }
                                    </ul>

                                    <div class="d-flex gap-2">
                                        <a asp-action="EditActivity" asp-route-id="@activity.Id" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i> Modifier
                                        </a>
                                        <form asp-action="DeleteActivity" asp-route-id="@activity.Id" method="post" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette activité ?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="bi bi-trash"></i> Supprimer
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                <div class="card-footer text-muted">
                                    <small>Créé le @activity.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Aucune activité créée. Cliquez sur "Créer une Activité" pour commencer.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
