@using UniHub.UI.Extensions
@{
    ViewData["Title"] = "Dashboard Étudiant";
    var myDeptActivities = ViewBag.MyDepartmentActivities as List<UniHub.BL.Entities.Activity>;
    var otherActivities = ViewBag.OtherActivities as List<UniHub.BL.Entities.Activity>;
    var userDept = (UniHub.BL.Entities.Department)ViewBag.UserDepartment;
    var userInscriptions = ViewBag.UserInscriptions as List<int> ?? new List<int>();
}

<div class="container mt-4">
    <h1 class="mb-4"><i class="bi bi-house-door"></i> Dashboard Étudiant - Département @userDept.GetDisplayName()</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Activités de mon département -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h4><i class="bi bi-calendar-check"></i> Activités de mon département (@userDept.GetDisplayName())</h4>
        </div>
        <div class="card-body">
            @if (myDeptActivities != null && myDeptActivities.Any())
            {
                <div class="row">
                    @foreach (var activity in myDeptActivities)
                    {
                        var currentParticipants = activity.Inscriptions?.Count ?? 0;
                        var isRegistered = userInscriptions.Contains(activity.Id);
                        var isFull = activity.MaxParticipants.HasValue && currentParticipants >= activity.MaxParticipants.Value;

                        <div class="col-md-6 mb-3">
                            <div class="card h-100 border-primary">
                                @if (activity.EventImage != null)
                                {
                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(activity.EventImage)" 
                                         class="card-img-top" alt="@activity.Title" style="max-height: 200px; object-fit: cover;" />
                                }
                                <div class="card-body">
                                    <h5 class="card-title">@activity.Title</h5>
                                    <p class="card-text">@activity.Description</p>
                                    <ul class="list-unstyled">
                                        <li><i class="bi bi-calendar"></i> <strong>Début:</strong> @activity.StartDate.ToString("dd/MM/yyyy HH:mm")</li>
                                        @if (activity.EndDate.HasValue)
                                        {
                                            <li><i class="bi bi-calendar"></i> <strong>Fin:</strong> @activity.EndDate.Value.ToString("dd/MM/yyyy HH:mm")</li>
                                        }
                                        @if (!string.IsNullOrEmpty(activity.Location))
                                        {
                                            <li><i class="bi bi-geo-alt"></i> <strong>Lieu:</strong> @activity.Location</li>
                                        }
                                        <li>
                                            <i class="bi bi-people"></i> <strong>Participants:</strong> 
                                            @currentParticipants@(activity.MaxParticipants.HasValue ? $"/{activity.MaxParticipants.Value}" : "")
                                            @if (isFull)
                                            {
                                                <span class="badge bg-danger ms-1">Complet</span>
                                            }
                                        </li>
                                        <li><i class="bi bi-person"></i> <strong>Créé par:</strong> @activity.CreatedByUser?.FullName</li>
                                    </ul>

                                    @if (isRegistered)
                                    {
                                        <form asp-controller="Student" asp-action="Unsubscribe" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="activityId" value="@activity.Id" />
                                            <button type="submit" class="btn btn-danger btn-sm w-100">
                                                <i class="bi bi-x-circle"></i> Se désinscrire
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-controller="Student" asp-action="Subscribe" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="activityId" value="@activity.Id" />
                                            <button type="submit" class="btn btn-success btn-sm w-100" @(isFull ? "disabled" : "")>
                                                <i class="bi bi-check-circle"></i> @(isFull ? "Complet" : "S'inscrire")
                                            </button>
                                        </form>
                                    }

                                    <!-- Section Commentaires (visible uniquement pour les activités du même département) -->
                                    <div class="mt-3">
                                        <h6><i class="bi bi-chat-dots"></i> Commentaires</h6>
                                        @if (activity.Comments != null && activity.Comments.Any())
                                        {
                                            <div class="list-group mb-2" style="max-height: 200px; overflow-y: auto;">
                                                @foreach (var comment in activity.Comments.OrderByDescending(c => c.CreatedDate))
                                                {
                                                    <div class="list-group-item">
                                                        <div class="d-flex justify-content-between">
                                                            <strong>@comment.User?.FullName</strong>
                                                            <small class="text-muted">@comment.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small>
                                                        </div>
                                                        <p class="mb-0">@comment.Content</p>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="text-muted small">Aucun commentaire pour le moment.</p>
                                        }

                                        <!-- Formulaire d'ajout de commentaire -->
                                        <form asp-controller="Student" asp-action="AddComment" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="activityId" value="@activity.Id" />
                                            <div class="input-group input-group-sm">
                                                <input type="text" name="content" class="form-control" placeholder="Ajouter un commentaire..." required />
                                                <button type="submit" class="btn btn-primary">
                                                    <i class="bi bi-send"></i>
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Aucune activité disponible pour votre département.
                </div>
            }
        </div>
    </div>

    <!-- Activités des autres départements -->
    <div class="card">
        <div class="card-header bg-secondary text-white">
            <h4><i class="bi bi-compass"></i> Découvrir les activités des autres départements</h4>
        </div>
        <div class="card-body">
            @if (otherActivities != null && otherActivities.Any())
            {
                <div class="row">
                    @foreach (var activity in otherActivities)
                    {
                        var currentParticipants = activity.Inscriptions?.Count ?? 0;
                        var isRegistered = userInscriptions.Contains(activity.Id);
                        var isFull = activity.MaxParticipants.HasValue && currentParticipants >= activity.MaxParticipants.Value;

                        <div class="col-md-6 mb-3">
                            <div class="card h-100">
                                <div class="card-header bg-light">
                                    <span class="badge bg-info">@activity.Department.GetDisplayName()</span>
                                </div>
                                @if (activity.EventImage != null)
                                {
                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(activity.EventImage)" 
                                         class="card-img-top" alt="@activity.Title" style="max-height: 200px; object-fit: cover;" />
                                }
                                <div class="card-body">
                                    <h5 class="card-title">@activity.Title</h5>
                                    <p class="card-text">@activity.Description</p>
                                    <ul class="list-unstyled">
                                        <li><i class="bi bi-calendar"></i> <strong>Début:</strong> @activity.StartDate.ToString("dd/MM/yyyy HH:mm")</li>
                                        @if (activity.EndDate.HasValue)
                                        {
                                            <li><i class="bi bi-calendar"></i> <strong>Fin:</strong> @activity.EndDate.Value.ToString("dd/MM/yyyy HH:mm")</li>
                                        }
                                        @if (!string.IsNullOrEmpty(activity.Location))
                                        {
                                            <li><i class="bi bi-geo-alt"></i> <strong>Lieu:</strong> @activity.Location</li>
                                        }
                                        <li>
                                            <i class="bi bi-people"></i> <strong>Participants:</strong> 
                                            @currentParticipants@(activity.MaxParticipants.HasValue ? $"/{activity.MaxParticipants.Value}" : "")
                                            @if (isFull)
                                            {
                                                <span class="badge bg-danger ms-1">Complet</span>
                                            }
                                        </li>
                                        <li><i class="bi bi-person"></i> <strong>Créé par:</strong> @activity.CreatedByUser?.FullName</li>
                                    </ul>

                                    @if (isRegistered)
                                    {
                                        <form asp-controller="Student" asp-action="Unsubscribe" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="activityId" value="@activity.Id" />
                                            <button type="submit" class="btn btn-danger btn-sm w-100">
                                                <i class="bi bi-x-circle"></i> Se désinscrire
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-controller="Student" asp-action="Subscribe" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="activityId" value="@activity.Id" />
                                            <button type="submit" class="btn btn-success btn-sm w-100" @(isFull ? "disabled" : "")>
                                                <i class="bi bi-check-circle"></i> @(isFull ? "Complet" : "S'inscrire")
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Aucune activité disponible dans les autres départements.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
