@{
    ViewData["Title"] = "Dashboard Étudiant";
    var myDeptActivities = ViewBag.MyDepartmentActivities as List<UniHub.BL.Entities.Activity>;
    var otherActivities = ViewBag.OtherActivities as List<UniHub.BL.Entities.Activity>;
    var userDept = (UniHub.BL.Entities.Department)ViewBag.UserDepartment;
}

<div class="container mt-4">
    <h1 class="mb-4"><i class="bi bi-house-door"></i> Dashboard Étudiant - Département @userDept</h1>

    <!-- Activités de mon département -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h4><i class="bi bi-calendar-check"></i> Activités de mon département (@userDept)</h4>
        </div>
        <div class="card-body">
            @if (myDeptActivities != null && myDeptActivities.Any())
            {
                <div class="row">
                    @foreach (var activity in myDeptActivities)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card h-100 border-primary">
                                <div class="card-body">
                                    <h5 class="card-title">@activity.Title</h5>
                                    <p class="card-text">@activity.Description</p>
                                    <ul class="list-unstyled">
                                        <li><i class="bi bi-calendar"></i> <strong>Début:</strong> @activity.StartDate.ToString("dd/MM/yyyy HH:mm")</li>
                                        @if (activity.EndDate.HasValue)
                                        {
                                            <li><i class="bi bi-calendar"></i> <strong>Fin:</strong> @activity.EndDate.Value.ToString("dd/MM/yyyy HH:mm")</li>
                                        }
                                        @if (!string.IsNullOrEmpty(activity.Location))
                                        {
                                            <li><i class="bi bi-geo-alt"></i> <strong>Lieu:</strong> @activity.Location</li>
                                        }
                                        @if (activity.MaxParticipants.HasValue)
                                        {
                                            <li><i class="bi bi-people"></i> <strong>Participants max:</strong> @activity.MaxParticipants</li>
                                        }
                                        <li><i class="bi bi-person"></i> <strong>Créé par:</strong> @activity.CreatedByUser.FullName</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Aucune activité disponible pour votre département.
                </div>
            }
        </div>
    </div>

    <!-- Activités des autres départements -->
    <div class="card">
        <div class="card-header bg-secondary text-white">
            <h4><i class="bi bi-compass"></i> Découvrir les activités des autres départements</h4>
        </div>
        <div class="card-body">
            @if (otherActivities != null && otherActivities.Any())
            {
                <div class="row">
                    @foreach (var activity in otherActivities)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card h-100">
                                <div class="card-header bg-light">
                                    <span class="badge bg-info">@activity.Department</span>
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title">@activity.Title</h5>
                                    <p class="card-text">@activity.Description</p>
                                    <ul class="list-unstyled">
                                        <li><i class="bi bi-calendar"></i> <strong>Début:</strong> @activity.StartDate.ToString("dd/MM/yyyy HH:mm")</li>
                                        @if (activity.EndDate.HasValue)
                                        {
                                            <li><i class="bi bi-calendar"></i> <strong>Fin:</strong> @activity.EndDate.Value.ToString("dd/MM/yyyy HH:mm")</li>
                                        }
                                        @if (!string.IsNullOrEmpty(activity.Location))
                                        {
                                            <li><i class="bi bi-geo-alt"></i> <strong>Lieu:</strong> @activity.Location</li>
                                        }
                                        <li><i class="bi bi-person"></i> <strong>Créé par:</strong> @activity.CreatedByUser.FullName</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Aucune activité disponible dans les autres départements.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
